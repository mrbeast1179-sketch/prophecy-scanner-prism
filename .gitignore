# >>> cvforge checkpoint ignores >>>
# cvforge checkpoints capture app code, never local keys or generated support.
.mcp.json
.claude/
.codex/
.cvforge/

# Regenerated by cvforge on app open/restore.
# Note: cv-bootstrap.js is the demo bootstrap shipped with this repo
# (re-included explicitly below). cvforge's overwrite-before-commit
# step is still safe because the runtime only erases the on-disk file,
# not the tracked blob; the file is gated at runtime by a ?demo=1
# query string so a host that provides its own window.cvApi has its
# data source respected under the canonical URL.
cv-bootstrap.js
!cv-bootstrap.js
CLAUDE.md
AGENTS.md
meta.json

# editor / OS / tooling noise
*~
*.swp
*.swx
.DS_Store
node_modules/
# <<< cvforge checkpoint ignores <<<
